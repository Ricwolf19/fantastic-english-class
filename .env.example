# ── Fantastic English Class — variables de entorno ──────────────────────────
# TODAS son OPCIONALES. El sitio renderiza y se puede deployar en Vercel sin
# ninguna configurada — ideal para mostrar la landing ya publicada. Cada
# variable solo ACTIVA una capa extra (envío de correo, protección anti-bot).
# Local: copia este archivo a `.env` y llena lo que quieras probar.

# URL pública del sitio (sin slash final). Debe ser el dominio canónico en
# producción; alimenta canonical, hreflang, sitemap y las OG images. Si se
# omite, cae a https://fantasticenglishclass.com. Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ── Formulario de contacto (Resend) ─────────────────────────────────────────
# Sin RESEND_API_KEY el formulario NO envía: devuelve un mensaje de error claro
# (no rompe la página). El resto del sitio y el botón de WhatsApp funcionan.
RESEND_API_KEY=
# Inbox que recibe los mensajes. Si se omite, usa el correo definido en
# lib/site.ts (site.contact.email).
CONTACT_TO_EMAIL=
# Remitente. "onboarding@resend.dev" sirve en modo test (solo entrega al dueño
# de la cuenta Resend); para producción, verifica un dominio y usa un remitente
# de ese dominio.
CONTACT_FROM_EMAIL=

# ── Anti-bot del formulario (reCAPTCHA v3) — opcional ───────────────────────
# Con AMBAS claves, el formulario verifica que quien envía es humano. Sin ellas,
# la verificación se OMITE (fail-open) y el formulario sigue funcionando: úsalas
# antes de exponer el sitio a tráfico real para evitar spam.
# Claves de https://www.google.com/recaptcha/admin (tipo reCAPTCHA v3).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
